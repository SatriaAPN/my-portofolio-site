# Copy this file to `.env` and fill in your key. `.env` is git-ignored.
# NEVER commit a real API key.

# Your Anthropic API key (get one at https://console.anthropic.com/).
# Without it, /api/chat returns 503 and the frontend uses local canned answers.
ANTHROPIC_API_KEY=

# Optional overrides:
# Claude model to use. Defaults to claude-opus-4-8 (most capable).
# For a cheaper/faster portfolio assistant, try claude-haiku-4-5 or claude-sonnet-5.
ANTHROPIC_MODEL=claude-opus-4-8

# Port the server listens on (the frontend dev proxy expects 8080).
PORT=8080

# Browser origin allowed via CORS (your frontend dev server).
ALLOWED_ORIGIN=http://localhost:5173
